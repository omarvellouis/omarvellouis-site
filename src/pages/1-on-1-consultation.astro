---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const consultationURL = "https://omarvellouis.com/1-on-1-consultation";
---

<BaseLayout 
  title="1-on-1 Consultation - Digital Ads Audit | omarvellouis"
  description="One-on-one consultation for campaign audit, strategy review, and custom optimization roadmap. Specialized in Shopee Ads, TikTok Ads & Meta Ads."
>
  <Header />
  
  <main>
    <section class="hero">
      <div class="container">
        <div class="hero-content">
          <span class="badge">1-on-1 Consultation</span>
          <h1 class="hero-title">
            Get Your Campaign Audited<br/>
            & <span class="highlight">Custom Roadmap</span> in 90 Minutes
          </h1>
          <p class="hero-description">
            Deep-dive consultation to identify bottlenecks, diagnose issues, 
            and build actionable optimization roadmap for your campaigns.
          </p>
          <div class="hero-price">
            <div class="price-tag">
              <span class="price">Rp750K</span>
              <span class="price-note">/ 90 minutes session</span>
            </div>
          </div>
          <a 
            href={consultationURL}
            class="btn btn-primary btn-lg"
            onclick="if(typeof fbq !== 'undefined') fbq('track', 'InitiateCheckout', {content_name: '1-on-1 Consultation'});"
          >
            Book Consultation Now
          </a>
        </div>
      </div>
    </section>

    <section class="benefits">
      <div class="container">
        <h2 class="section-title">What You'll Get</h2>
        
        <div class="benefits-grid">
          <div class="benefit-card">
            <div class="benefit-icon">🔍</div>
            <h3 class="benefit-title">Campaign Audit</h3>
            <p class="benefit-description">
              Complete audit for Shopee Ads (GMV Max/CPAS), TikTok Ads, or Meta Ads. 
              Identify bottlenecks, wasted spend, and missed opportunities.
            </p>
          </div>

          <div class="benefit-card">
            <div class="benefit-icon">📊</div>
            <h3 class="benefit-title">Data Analysis</h3>
            <p class="benefit-description">
              Deep-dive into campaign data: delivering rate, video contraction diagnosis, 
              SKU performance matrix, audience insights.
            </p>
          </div>

          <div class="benefit-card">
            <div class="benefit-icon">🎯</div>
            <h3 class="benefit-title">Strategy Review</h3>
            <p class="benefit-description">
              Review current strategy vs. best practices. Framework recommendation: 
              GMV Max, CPAS P.E.R.C, or custom approach.
            </p>
          </div>

          <div class="benefit-card">
            <div class="benefit-icon">🗺️</div>
            <h3 class="benefit-title">Custom Roadmap</h3>
            <p class="benefit-description">
              Step-by-step optimization roadmap with priority matrix. 
              Quick wins vs. long-term improvements.
            </p>
          </div>

          <div class="benefit-card">
            <div class="benefit-icon">📝</div>
            <h3 class="benefit-title">Actionable SOP</h3>
            <p class="benefit-description">
              Implementation guide to execute roadmap. 
              Setup checklist, monitoring dashboard template.
            </p>
          </div>

          <div class="benefit-card">
            <div class="benefit-icon">💬</div>
            <h3 class="benefit-title">14-Day Follow-up</h3>
            <p class="benefit-description">
              WhatsApp support for clarification & troubleshooting 
              during 14 days post-consultation.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .hero {
    padding: 80px 20px 60px;
    background: linear-gradient(135deg, #f8f9fa 0%, #e8f5e9 100%);
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .badge {
    display: inline-block;
    background: white;
    color: var(--color-primary);
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 24px;
    border: 1px solid var(--color-primary);
  }

  .hero-title {
    font-size: 52px;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 24px;
  }

  .highlight {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-description {
    font-size: 18px;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .hero-price {
    margin-bottom: 32px;
  }

  .price-tag {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 8px;
  }

  .price {
    font-size: 48px;
    font-weight: 800;
    color: var(--color-primary);
  }

  .price-note {
    font-size: 16px;
    color: var(--color-text-light);
  }

  .btn {
    display: inline-block;
    padding: 18px 36px;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 16px;
    transition: all 0.2s ease;
    cursor: pointer;
    text-decoration: none;
    border: none;
    background: var(--color-primary);
    color: white;
  }

  .btn:hover {
    background: var(--color-primary-dark);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .benefits {
    padding: 100px 20px;
  }

  .section-title {
    font-size: 42px;
    font-weight: 800;
    text-align: center;
    margin-bottom: 60px;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .benefit-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 32px;
    transition: all 0.3s ease;
  }

  .benefit-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-primary);
  }

  .benefit-icon {
    font-size: 48px;
    margin-bottom: 16px;
  }

  .benefit-title {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .benefit-description {
    color: var(--color-text-light);
    line-height: 1.6;
    font-size: 15px;
  }

  @media (max-width: 968px) {
    .hero-title {
      font-size: 38px;
    }

    .benefits-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 32px;
    }

    .price {
      font-size: 36px;
    }

    .section-title {
      font-size: 32px;
    }
  }
</style>
