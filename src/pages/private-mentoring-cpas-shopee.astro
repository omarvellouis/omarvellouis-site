---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const mentoringURL = "https://omarvellouis.com/private-mentoring-cpas-shopee";
---

<BaseLayout 
  title="Private Mentoring: CPAS Shopee Ads Mastery | omarvellouis"
  description="Intensive 1-on-1 mentoring program to master CPAS campaigns on Shopee with the P.E.R.C Framework."
>
  <Header />
  
  <main>
    <section class="mentoring-hero">
      <div class="container">
        <span class="badge">Private Mentoring</span>
        <h1 class="hero-title">
          CPAS Shopee Ads<br/>
          <span class="highlight">Mastery Program</span>
        </h1>
        <p class="hero-description">
          Intensive 1-on-1 mentoring to master CPAS campaigns using the proven 
          P.E.R.C Framework. Scale profitably with personalized guidance.
        </p>
        
        <a 
          href={mentoringURL}
          class="btn btn-primary btn-lg"
          onclick="if(typeof fbq !== 'undefined') fbq('track', 'Lead', {content_name: 'CPAS Mentoring'});"
        >
          Apply for Mentoring
        </a>

        <div class="program-details">
          <h3>Program Highlights:</h3>
          <ul>
            <li>✅ 12-Week Intensive Mentoring Program</li>
            <li>✅ Weekly 1-on-1 Strategy Sessions</li>
            <li>✅ P.E.R.C Framework Implementation</li>
            <li>✅ Live Campaign Audit & Optimization</li>
            <li>✅ Private WhatsApp Support Group</li>
            <li>✅ Custom Playbooks & SOPs</li>
            <li>✅ Performance Tracking Dashboard</li>
          </ul>

          <div class="ideal-for">
            <h4>Ideal For:</h4>
            <p>
              Brands spending Rp50 juta+/month on Shopee CPAS campaigns who want 
              to improve ROAS, reduce CPA, and scale profitably with expert guidance.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .mentoring-hero {
    padding: 80px 20px 100px;
    text-align: center;
  }

  .badge {
    display: inline-block;
    background: var(--color-primary-light);
    color: var(--color-primary);
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 24px;
    border: 1px solid var(--color-primary);
  }

  .hero-title {
    font-size: 48px;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 24px;
  }

  .highlight {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-description {
    font-size: 18px;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .btn {
    display: inline-block;
    padding: 18px 36px;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 16px;
    transition: all 0.2s ease;
    cursor: pointer;
    text-decoration: none;
    border: none;
    background: var(--color-primary);
    color: white;
  }

  .btn:hover {
    background: var(--color-primary-dark);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .program-details {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 40px;
    margin-top: 60px;
    text-align: left;
  }

  .program-details h3 {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 24px;
    text-align: center;
  }

  .program-details ul {
    list-style: none;
    padding: 0;
    margin-bottom: 32px;
  }

  .program-details li {
    font-size: 16px;
    line-height: 1.8;
    margin-bottom: 12px;
    color: var(--color-text);
  }

  .ideal-for {
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
  }

  .ideal-for h4 {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .ideal-for p {
    color: var(--color-text-light);
    line-height: 1.7;
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 32px;
    }

    .program-details {
      padding: 24px;
    }
  }
</style>
