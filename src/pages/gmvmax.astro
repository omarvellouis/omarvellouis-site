---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const courseURL = "https://omarvellouis.com/gmvmax";
---

<BaseLayout 
  title="GMV Max Framework Course - Growth Hack ROAS Shopee Ads"
  description="Master the proven GMV Max Framework to scale Shopee Ads campaigns profitably and reduce marketing costs."
>
  <Header />
  
  <main>
    <section class="course-hero">
      <div class="container">
        <span class="badge">E-Course</span>
        <h1 class="hero-title">
          Growth Hack ROAS Shopee Ads<br/>
          with <span class="highlight">GMV Max Framework</span>
        </h1>
        <p class="hero-description">
          Learn the exact framework I use to manage Rp2.8M+ GMV campaigns 
          and reduce marketing cost from 30% to 10%.
        </p>
        
        <a 
          href={courseURL}
          class="btn btn-primary btn-lg"
          onclick="if(typeof fbq !== 'undefined') fbq('track', 'InitiateCheckout', {content_name: 'GMV Max Course'});"
        >
          Akses Course Sekarang
        </a>
        
        <div class="course-modules">
          <h3>What You'll Learn:</h3>
          <ul>
            <li>✅ GMV Max Setup, Management & Troubleshooting SOP</li>
            <li>✅ Video Contraction Diagnosis Framework</li>
            <li>✅ Delivering Rate Optimization Strategies</li>
            <li>✅ Predictive GMV Modeling & Forecasting</li>
            <li>✅ Real Campaign Case Studies from FMCG & Fashion</li>
            <li>✅ Advanced Bidding Strategies</li>
          </ul>
        </div>

        <div class="social-proof">
          <p class="proof-text">
            <strong>Trusted by 100+ marketers</strong> managing Shopee campaigns 
            across Indonesia, Malaysia, and Singapore.
          </p>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .course-hero {
    padding: 80px 20px 100px;
    text-align: center;
  }

  .badge {
    display: inline-block;
    background: var(--color-primary-light);
    color: var(--color-primary);
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 24px;
    border: 1px solid var(--color-primary);
  }

  .hero-title {
    font-size: 48px;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 24px;
  }

  .highlight {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-description {
    font-size: 18px;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .btn {
    display: inline-block;
    padding: 18px 36px;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 16px;
    transition: all 0.2s ease;
    cursor: pointer;
    text-decoration: none;
    border: none;
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-primary-dark);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .btn-lg {
    padding: 18px 36px;
    font-size: 16px;
  }

  .course-modules {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 40px;
    margin-top: 60px;
    text-align: left;
  }

  .course-modules h3 {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 24px;
    text-align: center;
  }

  .course-modules ul {
    list-style: none;
    padding: 0;
  }

  .course-modules li {
    font-size: 16px;
    line-height: 1.8;
    margin-bottom: 12px;
    color: var(--color-text);
  }

  .social-proof {
    margin-top: 40px;
    padding: 24px;
    background: var(--color-background-alt);
    border-radius: var(--radius-md);
  }

  .proof-text {
    color: var(--color-text-light);
    font-size: 15px;
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 32px;
    }

    .course-modules {
      padding: 24px;
    }
  }
</style>
