---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout 
  title="Konsultasi Digital Ads - Rp750K | OmarVellouis"
  description="One-on-one consultation untuk campaign audit, strategy review, dan custom optimization roadmap. Specialized in Shopee Ads, TikTok Ads & Meta Ads."
>
  <Header />
  
  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="container">
        <div class="hero-content">
          <span class="badge">Konsultasi Digital Ads</span>
          <h1 class="hero-title">
            Get Your Campaign Audited<br/>
            & <span class="highlight">Custom Roadmap</span> in 90 Minutes
          </h1>
          <p class="hero-description">
            Deep-dive consultation untuk identify bottlenecks, diagnose issues, 
            dan build actionable optimization roadmap untuk campaign Anda.
          </p>
          <div class="hero-price">
            <div class="price-tag">
              <span class="price">Rp750K</span>
              <span class="price-note">/ 90 menit session</span>
            </div>
          </div>
          <a href="#book-now" class="btn btn-primary btn-lg">
            Book Konsultasi Sekarang
          </a>
        </div>
      </div>
    </section>

    <!-- What You Get Section -->
    <section class="benefits">
      <div class="container">
        <h2 class="section-title">Apa yang Anda Dapatkan</h2>
        
        <div class="benefits-grid">
          <div class="benefit-card">
            <div class="benefit-icon">🔍</div>
            <h3 class="benefit-title">Campaign Audit</h3>
            <p class="benefit-description">
              Complete audit untuk Shopee Ads (GMV Max/CPAS), TikTok Ads, atau Meta Ads. 
              Identify bottlenecks, waste spend, dan missed opportunities.
            </p>
          </div>

          <div class="benefit-card">
            <div class="benefit-icon">📊</div>
            <h3 class="benefit-title">Data Analysis</h3>
            <p class="benefit-description">
              Deep-dive ke campaign data: delivering rate, video contraction diagnosis, 
              SKU performance matrix, audience insights.
            </p>
          </div>

          <div class="benefit-card">
            <div class="benefit-icon">🎯</div>
            <h3 class="benefit-title">Strategy Review</h3>
            <p class="benefit-description">
              Review current strategy vs. best practices. Framework recommendation: 
              GMV Max, CPAS P.E.R.C, atau custom approach.
            </p>
          </div>

          <div class="benefit-card">
            <div class="benefit-icon">🗺️</div>
            <h3 class="benefit-title">Custom Roadmap</h3>
            <p class="benefit-description">
              Step-by-step optimization roadmap dengan priority matrix. 
              Quick wins vs. long-term improvements.
            </p>
          </div>

          <div class="benefit-card">
            <div class="benefit-icon">📝</div>
            <h3 class="benefit-title">Actionable SOP</h3>
            <p class="benefit-description">
              Implementation guide untuk execute roadmap. 
              Setup checklist, monitoring dashboard template.
            </p>
          </div>

          <div class="benefit-card">
            <div class="benefit-icon">💬</div>
            <h3 class="benefit-title">14-Day Follow-up</h3>
            <p class="benefit-description">
              WhatsApp support untuk clarification & troubleshooting 
              selama 14 hari post-consultation.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Who This Is For -->
    <section class="for-who">
      <div class="container">
        <h2 class="section-title">Ideal Untuk</h2>
        
        <div class="personas-grid">
          <div class="persona-card">
            <h3 class="persona-title">Brand Owners</h3>
            <p class="persona-description">
              GMV Rp300–800 juta/bulan yang stuck di plateau. 
              Marketing cost ratio tinggi, ROAS turun, tidak tau root cause.
            </p>
          </div>

          <div class="persona-card">
            <h3 class="persona-title">Marketing Managers</h3>
            <p class="persona-description">
              In-house marketer yang perlu second opinion, 
              framework validation, atau advanced troubleshooting.
            </p>
          </div>

          <div class="persona-card">
            <h3 class="persona-title">Agency Owners</h3>
            <p class="persona-description">
              Agency yang handle multi-client campaigns dan butuh 
              systematic approach untuk scale operation.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="process">
      <div class="container">
        <h2 class="section-title">Consultation Process</h2>
        
        <div class="process-steps">
          <div class="process-step">
            <div class="step-number">1</div>
            <div class="step-content">
              <h3 class="step-title">Pre-Consultation Brief</h3>
              <p class="step-description">
                Share campaign access & data 48 jam sebelum session. 
                Saya akan prepare audit findings terlebih dahulu.
              </p>
            </div>
          </div>

          <div class="process-step">
            <div class="step-number">2</div>
            <div class="step-content">
              <h3 class="step-title">90-Minute Deep-Dive</h3>
              <p class="step-description">
                Virtual meeting via Google Meet. Screen-sharing untuk walk through 
                audit findings, diagnose issues, discuss strategy.
              </p>
            </div>
          </div>

          <div class="process-step">
            <div class="step-number">3</div>
            <div class="step-content">
              <h3 class="step-title">Roadmap Delivery</h3>
              <p class="step-description">
                Custom optimization roadmap + implementation SOP dikirim 
                dalam 24 jam post-consultation.
              </p>
            </div>
          </div>

          <div class="process-step">
            <div class="step-number">4</div>
            <div class="step-content">
              <h3 class="step-title">14-Day Support</h3>
              <p class="step-description">
                WhatsApp follow-up untuk clarification, troubleshooting, 
                dan progress check-in.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section" id="book-now">
      <div class="container">
        <div class="cta-card">
          <h2 class="cta-title">Ready to Audit Your Campaign?</h2>
          <p class="cta-description">
            Limited slots per week. Book sekarang untuk secure slot Anda.
          </p>
          <div class="cta-price">
            <span class="price-large">Rp750K</span>
            <span class="price-subtext">One-time payment, 90 menit session</span>
          </div>
          <a 
            href="https://wa.me/6281234567890?text=Hi%20Omar%2C%20saya%20mau%20book%20konsultasi%20digital%20ads%20Rp750K" 
            class="btn btn-primary btn-lg"
            target="_blank"
            rel="noopener"
          >
            Book via WhatsApp
          </a>
          <p class="cta-note">
            Payment via transfer. Invoice akan dikirim setelah booking confirmation.
          </p>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Hero */
  .hero {
    padding: 80px 20px 60px;
    background: linear-gradient(135deg, #f8f9fa 0%, #e8f5e9 100%);
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .badge {
    display: inline-block;
    background: white;
    color: var(--color-primary);
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 24px;
    border: 1px solid var(--color-primary);
  }

  .hero-title {
    font-size: 52px;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 24px;
  }

  .highlight {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-description {
    font-size: 18px;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .hero-price {
    margin-bottom: 32px;
  }

  .price-tag {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 8px;
  }

  .price {
    font-size: 48px;
    font-weight: 800;
    color: var(--color-primary);
  }

  .price-note {
    font-size: 16px;
    color: var(--color-text-light);
  }

  /* Benefits */
  .benefits {
    padding: 100px 20px;
  }

  .section-title {
    font-size: 42px;
    font-weight: 800;
    text-align: center;
    margin-bottom: 60px;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .benefit-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 32px;
    transition: all 0.3s ease;
  }

  .benefit-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-primary);
  }

  .benefit-icon {
    font-size: 48px;
    margin-bottom: 16px;
  }

  .benefit-title {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .benefit-description {
    color: var(--color-text-light);
    line-height: 1.6;
    font-size: 15px;
  }

  /* For Who */
  .for-who {
    padding: 100px 20px;
    background: var(--color-background-alt);
  }

  .personas-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .persona-card {
    background: white;
    border-radius: var(--radius-md);
    padding: 32px;
    border: 2px solid var(--color-primary);
  }

  .persona-title {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--color-primary);
  }

  .persona-description {
    color: var(--color-text-light);
    line-height: 1.6;
  }

  /* Process */
  .process {
    padding: 100px 20px;
  }

  .process-steps {
    max-width: 800px;
    margin: 0 auto;
  }

  .process-step {
    display: flex;
    gap: 24px;
    margin-bottom: 40px;
    align-items: flex-start;
  }

  .step-number {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    background: var(--color-primary);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    font-weight: 800;
  }

  .step-content {
    flex: 1;
  }

  .step-title {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .step-description {
    color: var(--color-text-light);
    line-height: 1.6;
  }

  /* CTA Section */
  .cta-section {
    padding: 100px 20px;
  }

  .cta-card {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    border-radius: var(--radius-lg);
    padding: 60px 40px;
    text-align: center;
    color: white;
  }

  .cta-title {
    font-size: 42px;
    font-weight: 800;
    margin-bottom: 16px;
    color: white;
  }

  .cta-description {
    font-size: 18px;
    margin-bottom: 32px;
    opacity: 0.95;
  }

  .cta-price {
    margin-bottom: 32px;
  }

  .price-large {
    display: block;
    font-size: 64px;
    font-weight: 800;
    margin-bottom: 8px;
  }

  .price-subtext {
    display: block;
    font-size: 16px;
    opacity: 0.9;
  }

  .cta-note {
    margin-top: 20px;
    font-size: 14px;
    opacity: 0.85;
  }

  /* Buttons */
  .btn {
    display: inline-block;
    padding: 14px 28px;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 15px;
    transition: all 0.2s ease;
    cursor: pointer;
    text-decoration: none;
    border: none;
  }

  .btn-primary {
    background: white;
    color: var(--color-primary);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-xl);
  }

  .btn-lg {
    padding: 18px 36px;
    font-size: 16px;
  }

  /* Responsive */
  @media (max-width: 968px) {
    .hero-title {
      font-size: 38px;
    }

    .benefits-grid,
    .personas-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 32px;
    }

    .price {
      font-size: 36px;
    }

    .section-title {
      font-size: 32px;
    }

    .cta-title {
      font-size: 32px;
    }

    .price-large {
      font-size: 48px;
    }
  }
</style>

<script>
  // Facebook Pixel Custom Event
  if (typeof fbq !== 'undefined') {
    fbq('track', 'ViewContent', {
      content_name: 'Konsultasi Page',
      content_category: 'Service',
      value: 750000,
      currency: 'IDR'
    });
  }
</script>
