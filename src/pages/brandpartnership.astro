---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const partnershipURL = "https://omarvellouis.com/brandpartnership";
---

<BaseLayout 
  title="Brand Partnership - Digital Marketing Services | omarvellouis"
  description="Partner with omarvellouis for full-service digital marketing campaigns on Shopee, TikTok & Meta Ads."
>
  <Header />
  
  <main>
    <section class="partnership-hero">
      <div class="container">
        <span class="badge">Partnership</span>
        <h1 class="hero-title">
          Brand Partnership Program
        </h1>
        <p class="hero-description">
          Full-service digital marketing partnership for brands looking to scale 
          their e-commerce presence on Shopee, TikTok Shop & Meta platforms.
        </p>
        
        <a 
          href={partnershipURL}
          class="btn btn-primary btn-lg"
          onclick="if(typeof fbq !== 'undefined') fbq('track', 'Lead', {content_name: 'Brand Partnership'});"
        >
          Apply for Partnership
        </a>

        <div class="partnership-info">
          <h3>What's Included:</h3>
          <ul>
            <li>✅ Campaign Strategy & Planning</li>
            <li>✅ Full Campaign Setup & Management</li>
            <li>✅ Creative & Ad Copy Development</li>
            <li>✅ Performance Optimization & Scaling</li>
            <li>✅ Weekly Performance Reports</li>
            <li>✅ Direct Access to Strategy Consultant</li>
          </ul>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .partnership-hero {
    padding: 80px 20px 100px;
    text-align: center;
  }

  .badge {
    display: inline-block;
    background: #fce4ec;
    color: #c2185b;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 24px;
  }

  .hero-title {
    font-size: 48px;
    font-weight: 800;
    margin-bottom: 24px;
  }

  .hero-description {
    font-size: 18px;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .btn {
    display: inline-block;
    padding: 18px 36px;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 16px;
    transition: all 0.2s ease;
    cursor: pointer;
    text-decoration: none;
    border: none;
    background: var(--color-primary);
    color: white;
  }

  .btn:hover {
    background: var(--color-primary-dark);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .partnership-info {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 40px;
    margin-top: 60px;
    text-align: left;
  }

  .partnership-info h3 {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 24px;
    text-align: center;
  }

  .partnership-info ul {
    list-style: none;
    padding: 0;
  }

  .partnership-info li {
    font-size: 16px;
    line-height: 1.8;
    margin-bottom: 12px;
    color: var(--color-text);
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 32px;
    }

    .partnership-info {
      padding: 24px;
    }
  }
</style>
